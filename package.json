{
	"name": "gamebuds",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"format": "prettier --write . && pnpm --recursive --if-present run format",
		"format-check": "prettier --check . && pnpm --recursive --if-present run format-check",
		"lint": "pnpm --recursive --if-present run lint",
		"types": "pnpm --recursive --if-present run types",
		"test": "pnpm --recursive --if-present run test",
		"build": "pnpm --recursive --if-present run build",
		"checks": "pnpm run \"/^(types|lint|format-check|test|build)$/\""
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"eslint": "10.7.0",
		"prettier": "3.9.5",
		"typescript": "6.0.3",
		"typescript-eslint": "8.63.0",
		"vitest": "4.1.10"
	}
}
