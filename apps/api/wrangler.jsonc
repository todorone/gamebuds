{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gamebuds",
	"main": "src/worker.ts",
	"compatibility_date": "2025-07-01",
	"vars": {
		"CORS_ORIGINS": "http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173,capacitor://localhost,http://localhost,https://localhost,https://game-buds.com,https://www.game-buds.com",
	},
	"routes": [
		{
			"pattern": "app.game-buds.com",
			"custom_domain": true,
		},
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "gamebuds",
			"database_id": "c262b79c-8b39-41b0-8f0e-5e556798af5d",
			"migrations_dir": "drizzle/migrations",
		},
	],
}
